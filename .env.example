# ---------------------------------------------------------------------------
# pd-agent environment configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in values for
# your local machine. All variables here are optional unless you use the
# feature that needs them.
# ---------------------------------------------------------------------------

# Anthropic API key for LLM-powered commands like `pd-agent explain`.
# Get one at https://console.anthropic.com/ (Billing -> add credit, then
# Settings -> API Keys -> Create Key).
# Either name works; ANTHROPIC_API_KEY is the industry-standard name and
# takes precedence over the prefixed one.
ANTHROPIC_API_KEY=

# Optional: pin a specific Claude model (defaults to claude-sonnet-4-5).
# PD_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: path to your local openlane2 clone
# (defaults to ~/Documents/Projects/openlane2).
# PD_AGENT_OPENLANE2_REPO=/absolute/path/to/openlane2
