# ---------------------------------------------------------------------------
# pd-agent environment configuration
#
# Copy this file to `.env` (which is git-ignored) and fill in values for
# your local machine. All variables here are optional unless you use the
# feature that needs them.
# ---------------------------------------------------------------------------

# Anthropic API key for LLM-powered commands like `pd-agent explain`.
# Get one at https://console.anthropic.com/ (Billing -> add credit, then
# Settings -> API Keys -> Create Key).
# Either name works; ANTHROPIC_API_KEY is the industry-standard name and
# takes precedence over the prefixed one.
ANTHROPIC_API_KEY=

# Optional: pin a specific Claude model (defaults to claude-sonnet-4-5).
# PD_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: path to your local openlane2 clone
# (defaults to ~/Documents/Projects/openlane2).
# PD_AGENT_OPENLANE2_REPO=/absolute/path/to/openlane2

# ---------------------------------------------------------------------------
# RAG (phase 3) — embeddings and re-ranking
# ---------------------------------------------------------------------------

# Voyage AI API key for embeddings.
# Get one at https://www.voyageai.com/ (API Keys -> Create new secret key).
# Free tier: 200M tokens/month, more than enough for development.
VOYAGE_API_KEY=

# Optional: pin a specific Voyage embedding model (defaults to voyage-3-lite).
# PD_AGENT_VOYAGE_EMBEDDING_MODEL=voyage-3-lite

# Cohere API key for re-ranking retrieved chunks.
# Get a free Trial key at https://dashboard.cohere.com/ (API Keys section).
COHERE_API_KEY=

# Optional: pin a specific Cohere rerank model (defaults to rerank-v3.5).
# PD_AGENT_COHERE_RERANK_MODEL=rerank-v3.5

# Optional: paths for RAG corpus and persisted index. Defaults are relative
# to the directory where `pd-agent` is invoked.
# PD_AGENT_RAG_CORPUS_DIR=data/corpus
# PD_AGENT_RAG_INDEX_DIR=data/index
